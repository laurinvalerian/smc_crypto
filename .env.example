# ═══════════════════════════════════════════════════════════════════
#  SMC Multi-Asset Trading Bot — Environment Variables
#  Copy this file to .env and fill in your API keys.
#  NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════════════

# ── Binance Futures Testnet ──────────────────────────────────────
BINANCE_API_KEY=your_binance_testnet_api_key
BINANCE_SECRET=your_binance_testnet_secret

# ── Binance Futures Live (uncomment when ready) ─────────────────
# BINANCE_LIVE_API_KEY=your_binance_live_api_key
# BINANCE_LIVE_SECRET=your_binance_live_secret

# ── OANDA Practice (Forex + Commodities) ────────────────────────
OANDA_ACCESS_TOKEN=your_oanda_practice_api_token
OANDA_ACCOUNT_ID=your_oanda_account_id

# ── Alpaca Paper Trading (US Stocks) ────────────────────────────
ALPACA_API_KEY=your_alpaca_paper_api_key
ALPACA_API_SECRET=your_alpaca_paper_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
