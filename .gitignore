# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Environment variables
.env
docker/.env

# Data files (large, regenerable)
data/
*.parquet
*.h5

# Models (regenerable from training) — use `models/*` (not `models/`) so
# code files like student_brain.py can be re-included below. Git refuses to
# re-include files whose parent directory is itself excluded.
models/*
# Exceptions: loader + wrapper code is versioned (the trained .pkl stay ignored).
!models/student_brain.py

# Binary / data artifacts
*.pkl
*.pt
*.db
*.sqlite3

# Backtest results (regenerable)
backtest/results/
!backtest/results/.gitkeep

# Live results (runtime generated)
live_results/

# Paper grid results (runtime generated)
paper_grid_results/
!paper_grid_results/.gitkeep

# Snapshots and analysis output (large, regenerable)
snapshots/
hybrid_results/
replay_results/

# Logs
*.log

# RL model checkpoints
rl_models/

# OMC / Claude state
.omc/
.claude/
project-memory.json

# CSV results
*.csv
!requirements.txt
.coverage
